# Beehiiv (https://developers.beehiiv.com)
# Publication ID: Beehiiv dashboard -> Settings -> Publication -> Publication ID (empieza con "pub_")
# API Key: Beehiiv dashboard -> Settings -> Integrations -> API -> Create API Key
BEEHIIV_PUBLICATION_ID=
BEEHIIV_API_KEY=

# Resend (https://resend.com) — para el formulario de contacto (/contacto)
# API Key: Resend dashboard -> API Keys -> Create API Key
# CONTACT_TO_EMAIL: el correo donde quieres recibir los mensajes del formulario
RESEND_API_KEY=
CONTACT_TO_EMAIL=
