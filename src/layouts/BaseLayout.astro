---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import { getAlternateLangPath, type Lang } from "../i18n/translations";

interface Props {
  title: string;
  description: string;
  path?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
  lang?: Lang;
}

const {
  title,
  description,
  path = "/",
  // TODO: exportar este SVG a PNG/JPG (1200x630) antes de publicar — algunas
  // plataformas (Facebook, LinkedIn) no renderizan bien previews en SVG.
  ogImage = "/og-image.svg",
  jsonLd,
  noindex = false,
  lang = "es",
} = Astro.props;

const canonicalURL = new URL(path, Astro.site);
const alternatePath = getAlternateLangPath(path, lang);
const alternateURL = new URL(alternatePath, Astro.site);
const siteName = "amelinita";
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteName,
  url: Astro.site?.toString(),
  description:
    "Recursos gratuitos para hispanohablantes que quieren aprender coreano: PDFs, videos y más.",
  inLanguage: lang,
};

const jsonLdBlocks = [websiteJsonLd, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang={lang === "es" ? "es-419" : "ko"} href={canonicalURL} />
    <link rel="alternate" hreflang={lang === "es" ? "ko" : "es-419"} href={alternateURL} />
    <link rel="alternate" hreflang="x-default" href={lang === "es" ? canonicalURL : alternateURL} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={lang === "es" ? "es_419" : "ko_KR"} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    {jsonLdBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </head>
  <body class="bg-white text-neutral-900 antialiased">
    <Header lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
    <LanguageSwitcher lang={lang} currentPath={path} />
  </body>
</html>
