---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import AdSlot from "../../../components/AdSlot.astro";
import EmailGateModal from "../../../components/EmailGateModal.astro";
import { pdfs, pdfContent } from "../../../data/pdfs";

export function getStaticPaths() {
  return pdfs.map((pdf) => ({
    params: { slug: pdf.slug },
    props: { pdf },
  }));
}

const { pdf } = Astro.props;
const content = pdfContent(pdf, "ko");
const description = `${content.description} "${content.title}" 무료 다운로드, 스페인어권 학습자를 위한 자료예요.`;
---

<BaseLayout
  title={content.title}
  description={description}
  path={`/ko/recursos-pdf/${pdf.slug}/`}
  lang="ko"
>
  <div class="mx-auto max-w-2xl px-4 sm:px-6 py-14 sm:py-20">
    <a href="/ko/recursos-pdf/" class="text-sm font-600 text-brand-600 hover:text-brand-700">
      ← 모든 PDF 보기
    </a>

    <span class="mt-4 inline-block rounded-full bg-brand-100 px-4 py-1 text-xs font-700 uppercase tracking-wide text-brand-700">
      {content.tag}
    </span>
    <h1 class="font-heading mt-4 text-3xl sm:text-4xl font-800 text-neutral-900">{content.title}</h1>
    <p class="mt-4 text-neutral-600 leading-relaxed">{content.longDescription}</p>

    <div class="mt-8">
      <EmailGateModal pdfSlug={pdf.slug} pdfTitle={content.title} fileUrl={pdf.fileUrl} lang="ko" />
    </div>

    <AdSlot position="mid-content" sizeLabel="300x250" lang="ko" />
  </div>
</BaseLayout>
