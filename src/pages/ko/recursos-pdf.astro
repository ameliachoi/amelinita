---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdSlot from "../../components/AdSlot.astro";
import ResourceCard from "../../components/ResourceCard.astro";
import NewsletterSignupUI from "../../components/NewsletterSignupUI.astro";
import { pdfs, pdfContent } from "../../data/pdfs";

const description =
  "무료 한국어 PDF 자료: 한글, 어휘, 문법, 스페인어권 학습자를 위한 실용 표현까지.";

const half = Math.ceil(pdfs.length / 2);
const firstHalf = pdfs.slice(0, half);
const secondHalf = pdfs.slice(half);
---

<BaseLayout
  title="한국어 학습 PDF 자료"
  description={description}
  path="/ko/recursos-pdf/"
  lang="ko"
>
  <section class="bg-neutral-50 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 text-center">
      <span class="inline-block rounded-full bg-brand-100 px-4 py-1 text-xs font-700 uppercase tracking-wide text-brand-700">
        💜 무료 자료
      </span>
      <h1 class="font-heading mt-4 text-3xl sm:text-4xl font-800 text-neutral-900">
        한국어 학습 PDF, 무료로 받아보세요 📚
      </h1>
      <p class="mt-4 text-neutral-600">
        가이드, 어휘 목록, 문법 설명까지 — 스페인어권 학습자를 위해 만들었어요. 필요한 것부터
        천천히 받아보세요.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <AdSlot position="post-intro" sizeLabel="728x90 / responsive" lang="ko" />

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 py-4">
      {firstHalf.map((pdf) => (
        <ResourceCard title={pdfContent(pdf, "ko").title} description={pdfContent(pdf, "ko").description} tag={pdfContent(pdf, "ko").tag} badge="무료">
          <Fragment slot="action">
            <a href={`/ko/recursos-pdf/${pdf.slug}/`} class="text-sm font-600 text-brand-600 hover:text-brand-700">
              보고 다운로드하기 💜
            </a>
          </Fragment>
        </ResourceCard>
      ))}
    </div>

    {secondHalf.length > 0 && (
      <>
        <AdSlot position="mid-content" sizeLabel="300x250" lang="ko" />

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 py-4">
          {secondHalf.map((pdf) => (
            <ResourceCard title={pdfContent(pdf, "ko").title} description={pdfContent(pdf, "ko").description} tag={pdfContent(pdf, "ko").tag} badge="무료">
              <Fragment slot="action">
                <a href={`/ko/recursos-pdf/${pdf.slug}/`} class="text-sm font-600 text-brand-600 hover:text-brand-700">
                  보고 다운로드하기 💜
                </a>
              </Fragment>
            </ResourceCard>
          ))}
        </div>
      </>
    )}

    <div class="py-8 max-w-xl mx-auto">
      <NewsletterSignupUI
        lang="ko"
        title="새 PDF 소식을 받아보세요 💌"
        description="이메일을 남겨주시면 새 자료가 올라올 때 알려드려요 (준비 중)."
      />
    </div>

    <AdSlot position="pre-footer" sizeLabel="728x90 / responsive" lang="ko" />
  </div>
</BaseLayout>
