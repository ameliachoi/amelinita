---
import BaseLayout from "../layouts/BaseLayout.astro";
import AdSlot from "../components/AdSlot.astro";
import ContactForm from "../components/ContactForm.astro";

const description =
  "Contacta a amelinita para colaboraciones, preguntas sobre los recursos de coreano o cualquier otra consulta.";
---

<BaseLayout
  title="Contacto"
  description={description}
  path="/contacto/"
>
  <section class="bg-gradient-to-br from-brand-600 to-brand-800 py-16 sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 text-center">
      <span class="inline-block rounded-full bg-white/10 px-4 py-1 text-xs font-700 uppercase tracking-wide text-brand-100 ring-1 ring-white/20">
        Contacto
      </span>
      <h1 class="font-heading mt-4 text-3xl sm:text-4xl font-800 text-white">
        Escríbeme 💌
      </h1>
      <p class="mt-4 text-brand-100">
        ¿Tienes una pregunta, sugerencia o quieres colaborar? Completa el formulario o
        escríbeme directamente por TikTok.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-xl px-4 sm:px-6 py-14">
    <ContactForm />
    <AdSlot position="footer-minimal" />
  </div>
</BaseLayout>
