---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAButton from "../components/CTAButton.astro";
---

<BaseLayout
  title="Página no encontrada"
  description="La página que buscas no existe o fue movida."
  path="/404/"
>
  <section class="mx-auto max-w-2xl px-4 sm:px-6 py-24 text-center">
    <p class="font-heading text-6xl font-800 text-brand-600">404</p>
    <h1 class="font-heading mt-4 text-2xl sm:text-3xl font-800 text-neutral-900">
      Esta página no existe
    </h1>
    <p class="mt-3 text-neutral-500">
      Puede que el enlace esté roto o que la página se haya movido. Vuelve al inicio para
      seguir explorando los recursos de coreano.
    </p>
    <div class="mt-8">
      <CTAButton href="/" class="bg-brand-600 hover:bg-brand-700 text-white">Volver al inicio</CTAButton>
    </div>
  </section>
</BaseLayout>
