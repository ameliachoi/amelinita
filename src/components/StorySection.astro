---
interface Props {
  eyebrow: string;
  title: string;
  reverse?: boolean;
  bgClass?: string;
}

const { eyebrow, title, reverse = false, bgClass = "bg-white" } = Astro.props;
---

<section class:list={[bgClass, "py-16 sm:py-24"]}>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div
      class:list={[
        "grid items-center gap-10 md:grid-cols-2 md:gap-16",
        reverse && "md:[&>*:first-child]:order-2",
      ]}
    >
      <div>
        <span class="inline-block rounded-full bg-brand-100 px-4 py-1 text-xs font-700 uppercase tracking-wide text-brand-700">
          {eyebrow}
        </span>
        <h2 class="font-heading mt-4 text-2xl sm:text-3xl font-800 text-neutral-900">{title}</h2>
        <div class="mt-4 space-y-4 text-neutral-600 leading-relaxed">
          <slot name="body" />
        </div>
        <div class="mt-6">
          <slot name="cta" />
        </div>
      </div>
      <div class="flex justify-center">
        <slot name="illustration" />
      </div>
    </div>
  </div>
</section>
