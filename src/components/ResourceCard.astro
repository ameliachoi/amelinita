---
interface Props {
  title: string;
  description: string;
  tag: string;
  badge?: string;
}

const { title, description, tag, badge = "Gratis" } = Astro.props;
---

<article class="flex flex-col rounded-2xl bg-white p-6 shadow-sm ring-1 ring-neutral-100 transition-shadow hover:shadow-md">
  <div class="flex items-center justify-between">
    <span class="rounded-full bg-brand-50 px-3 py-1 text-xs font-600 text-brand-700">{tag}</span>
    <span class="rounded-full bg-accent-100 px-3 py-1 text-xs font-700 text-accent-700">{badge}</span>
  </div>
  <h3 class="font-heading mt-4 text-lg font-700 text-neutral-900">{title}</h3>
  <p class="mt-2 flex-1 text-sm text-neutral-500">{description}</p>
  <div class="mt-4">
    <slot name="action" />
  </div>
</article>
