---
interface Props {
  href: string;
  variant?: "solid" | "outline";
  class?: string;
}

const { href, variant = "solid", class: className = "" } = Astro.props;

const base = "inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 text-sm font-600 transition-colors";
const variants = {
  solid: "bg-brand-600 text-white hover:bg-brand-700 shadow-lg shadow-brand-900/20",
  outline: "border-2 border-white text-white hover:bg-white/10",
};
---

<a href={href} class:list={[base, variants[variant], className]}>
  <slot />
</a>
