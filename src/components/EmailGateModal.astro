---
// Modal de "email a cambio del PDF" (lead magnet).
// Envía el correo a /api/subscribe, que lo registra en Beehiiv.
// Requiere las variables de entorno BEEHIIV_API_KEY y BEEHIIV_PUBLICATION_ID
// (ver README) — sin ellas, /api/subscribe responde 503 y el modal muestra un error.
import { useTranslations, type Lang } from "../i18n/translations";

interface Props {
  pdfSlug: string;
  pdfTitle: string;
  fileUrl: string;
  lang?: Lang;
}

const { pdfSlug, pdfTitle, fileUrl, lang = "es" } = Astro.props;
const t = useTranslations(lang);
const descargaPath = lang === "ko" ? "/ko/recursos-pdf/descarga/" : "/recursos-pdf/descarga/";
---

<button
  type="button"
  id="open-download-modal"
  class="inline-flex items-center justify-center gap-2 rounded-full bg-brand-600 px-8 py-3.5 text-sm font-600 text-white shadow-lg shadow-brand-900/20 transition-colors hover:bg-brand-700"
>
  {t("modal.openButton")}
</button>

<dialog
  id="download-modal"
  data-pdf-slug={pdfSlug}
  data-pdf-title={pdfTitle}
  data-file-url={fileUrl}
  data-descarga-path={descargaPath}
  data-t-invalid-email={t("modal.invalidEmail")}
  data-t-generic-error={t("modal.genericError")}
  data-t-network-error={t("modal.networkError")}
  data-t-submit={t("modal.submit")}
  data-t-submitting={t("modal.submitting")}
  class="m-auto w-full max-w-sm rounded-2xl p-0 backdrop:bg-brand-900/60 open:animate-none"
>
  <form id="download-form" class="p-6 sm:p-8">
    <h3 class="font-heading text-lg font-700 text-neutral-900">{t("modal.title")}</h3>
    <p class="mt-1.5 text-sm text-neutral-500">
      {t("modal.description")} <strong>{pdfTitle}</strong>.
    </p>

    <label for="modal-email" class="sr-only">{t("modal.emailLabel")}</label>
    <input
      id="modal-email"
      name="email"
      type="email"
      required
      placeholder={t("modal.emailPlaceholder")}
      class="mt-4 w-full rounded-lg border border-neutral-200 px-4 py-2.5 text-sm placeholder:text-neutral-400 focus:outline-none focus:ring-2 focus:ring-brand-400"
    />
    <p id="modal-error" class="mt-1.5 hidden text-xs text-red-500"></p>

    <div class="mt-5 flex gap-3">
      <button
        type="button"
        id="close-download-modal"
        class="flex-1 rounded-full border border-neutral-200 px-4 py-2.5 text-sm font-600 text-neutral-600 hover:bg-neutral-50"
      >
        {t("modal.cancel")}
      </button>
      <button
        type="submit"
        id="submit-download-modal"
        class="flex-1 rounded-full bg-brand-600 px-4 py-2.5 text-sm font-600 text-white hover:bg-brand-700 disabled:cursor-not-allowed disabled:opacity-60"
      >
        {t("modal.submit")}
      </button>
    </div>

    <p class="mt-3 text-[11px] text-neutral-400">
      {t("modal.privacy")}
    </p>
  </form>
</dialog>

<script>
  const openBtn = document.querySelector<HTMLButtonElement>("#open-download-modal");
  const closeBtn = document.querySelector<HTMLButtonElement>("#close-download-modal");
  const modal = document.querySelector<HTMLDialogElement>("#download-modal");
  const form = document.querySelector<HTMLFormElement>("#download-form");
  const emailInput = document.querySelector<HTMLInputElement>("#modal-email");
  const errorMsg = document.querySelector<HTMLParagraphElement>("#modal-error");
  const submitBtn = document.querySelector<HTMLButtonElement>("#submit-download-modal");

  openBtn?.addEventListener("click", () => modal?.showModal());
  closeBtn?.addEventListener("click", () => modal?.close());
  modal?.addEventListener("click", (event) => {
    if (event.target === modal) modal.close();
  });

  function showError(message: string) {
    if (!errorMsg) return;
    errorMsg.textContent = message;
    errorMsg.classList.remove("hidden");
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const email = emailInput?.value.trim() ?? "";
    const isValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    const d = modal?.dataset ?? {};

    if (!isValid) {
      showError(d.tInvalidEmail ?? "Invalid email");
      return;
    }
    errorMsg?.classList.add("hidden");

    const pdfTitle = d.pdfTitle ?? "";
    const fileUrl = d.fileUrl ?? "";

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = d.tSubmitting ?? "...";
    }

    try {
      const res = await fetch("/api/subscribe", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, pdfSlug: d.pdfSlug, pdfTitle }),
      });
      const data = await res.json().catch(() => ({}));

      if (!res.ok) {
        showError(data.error ?? d.tGenericError ?? "Error");
        return;
      }

      // Datos para mostrar en la página de descarga (no es persistencia real,
      // el correo ya quedó guardado del lado de Beehiiv en el paso anterior).
      sessionStorage.setItem(
        "pdfDownloadRequest",
        JSON.stringify({ title: pdfTitle, fileUrl, email })
      );
      window.location.href = d.descargaPath ?? "/recursos-pdf/descarga/";
    } catch {
      showError(d.tNetworkError ?? "Network error");
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = d.tSubmit ?? "Submit";
      }
    }
  });
</script>
